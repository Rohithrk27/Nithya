{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/asset-manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/privacy-policy(\\.html)?",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/downloads/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/((?!api/|assets/|logo/|downloads/|manifest\\.json|asset-manifest\\.json|sw\\.js|favicon\\.ico|privacy-policy(?:\\.html)?).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/download-apk",
      "destination": "/downloads/Nithya.apk",
      "permanent": false
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!api/|assets/|logo/|downloads/|manifest\\.json|asset-manifest\\.json|sw\\.js|favicon\\.ico|privacy-policy(?:\\.html)?).*)", "destination": "/" }
  ]
}
