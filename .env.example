# Client-safe variables only (bundled into the app). Do NOT put private secrets here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_public_anon_key
VITE_PUBLIC_WEB_URL=https://nithya.fit
VITE_APP_BASE_URL=https://nithya.fit
VITE_APP_ID=nithya
VITE_FUNCTIONS_VERSION=1
VITE_WEB_PUSH_PUBLIC_KEY=your_public_web_push_key
VITE_UPI_ID=your-upi-id@bank

# Server-only variables (keep private, never prefix with VITE_).
# UPI_ID is read by /api/config on the server.
UPI_ID=your-upi-id@bank
